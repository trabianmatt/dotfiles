# For timing information, uncomment the zmodload line at the top and the zprof line at the bottom
# zmodload zsh/zprof

# shortcut to this dotfiles path is $ZSH
export ZSH=$HOME/.dotfiles

# your project folder that we can `c [tab]` to
export PROJECTS=~/dev

# Stash your environment variables in ~/.localrc. This means they'll stay out
# of your main dotfiles repository (which may be public, like this one), but
# you'll have access to them in your scripts.
if [[ -a ~/.localrc ]]
then
  source ~/.localrc
fi

# all of our zsh files
typeset -U config_files
config_files=($ZSH/**/*.zsh)

# load the path files
for file in ${(M)config_files:#*/path.zsh}
do
  source $file
done

# load everything but the path and completion files
for file in ${${config_files:#*/path.zsh}:#*/completion.zsh}
do
  source $file
done

# initialize autocomplete here, otherwise functions won't be loaded
autoload -U compinit
compinit

# load every completion after autocomplete loads
for file in ${(M)config_files:#*/completion.zsh}
do
  source $file
done

unset config_files

# Better history
# Credits to https://coderwall.com/p/jpj_6q/zsh-better-history-searching-with-arrow-keys
autoload -U up-line-or-beginning-search
autoload -U down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search

bindkey -e

bindkey "^[[A" up-line-or-beginning-search # Up
bindkey "^[[B" down-line-or-beginning-search # Down

[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# echo -e 'if command -v pyenv 1>/dev/null 2>&1; then\n  eval "$(pyenv init -)"\nfi'
# export PYENV_ROOT="$HOME/.pyenv"
# export PATH="$PYENV_ROOT/bin:$PATH"

# golang
export GOPATH=$HOME/go
export PATH="/Applications/Docker.app/Contents/Resources/bin:$GOPATH/bin:$PATH"

# Devcontainer tools (dc, etc.)
export PATH="$HOME/dev/devcontainer-dotfiles/bin:$PATH"

eval "$(direnv hook zsh)"
# eval "$(rbenv init - zsh)"

# VSCode is setting this to `0` for some reason, which causes crashes in some libraries
# unset MallocNanoZone

# source /Users/mattdean/.antilles/antilles_completion.zsh

# . "$HOME/.cargo/env"

export STARSHIP_CONFIG=$ZSH/starship/starship.toml

eval "$(starship init zsh)"

# Print timing information for each command
# zprof

. "$HOME/.local/bin/env"

export JAVA_HOME=$(/usr/libexec/java_home)
export PATH=$JAVA_HOME/bin:$PATH
eval "$(~/.local/try.rb init ~/dev/tries)"

export EDITOR=hx

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	IFS= read -r -d '' cwd < "$tmp"
	[ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && builtin cd -- "$cwd"
	rm -f -- "$tmp"
}

eval "$(zoxide init zsh)"

# This is for Claude Code to be able to use LSP tools
export ENABLE_LSP_TOOLS=1

alias chrome-debug='~/.pi/agent/skills/web-browser/start-chrome.sh'

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/mattdean/dev/tools/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/mattdean/dev/tools/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/mattdean/dev/tools/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/mattdean/dev/tools/google-cloud-sdk/completion.zsh.inc'; fi
